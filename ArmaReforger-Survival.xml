<?xml version="1.0"?>
<Container version="1">
    <Name>Arma_ReforgedZ</Name>
    <Repository>neuros1s/reforger-survival-server:latest</Repository>
    <Registry>https://hub.docker.com/r/neuros1s/reforger-survival-server</Registry>
    <Network>bridge</Network>
    <MyIP/>
    <Shell>sh</Shell>
    <Privileged>false</Privileged>
    <Support>https://github.com/neuros1s/reforger-survival-server/issues</Support>
    <Project>https://github.com/neuros1s/reforger-survival-server</Project>
    <Overview>Custom Arma Reforger survival server container for Unraid.</Overview>
    <Category>GameServers:</Category>
    <WebUI/>
    <TemplateURL/>
    <Icon>https://raw.githubusercontent.com/neuros1s/reforger-survival-server/main/assets/reforger-survival.png</Icon>
    <ExtraParams>--restart=unless-stopped</ExtraParams>

    <Config Name="SteamCMD Path" Target="/serverdata/steamcmd" Default="" Mode="rw" Description="SteamCMD install path" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/steamcmd</Config>
    <Config Name="Server Files Path" Target="/serverdata/serverfiles" Default="" Mode="rw" Description="Game files and profile path" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/reforger-survival</Config>

    <Config Name="Server Name" Target="GAME_NAME" Default="" Mode="" Description="Server display name" Type="Variable" Display="always" Required="true" Mask="false">HouseWolf | Chernarus Survival</Config>
    <Config Name="Server Password" Target="GAME_PASSWORD" Default="" Mode="" Description="Optional join password" Type="Variable" Display="always" Required="false" Mask="false"></Config>
    <Config Name="Admin Password" Target="GAME_PASSWORD_ADMIN" Default="" Mode="" Description="Admin password" Type="Variable" Display="always" Required="true" Mask="true"></Config>
    <Config Name="RCON Password" Target="RCON_PASSWORD" Default="" Mode="" Description="RCON password" Type="Variable" Display="always" Required="true" Mask="true"></Config>
    <Config Name="Scenario ID" Target="GAME_SCENARIO_ID" Default="" Mode="" Description="Scenario ID" Type="Variable" Display="always" Required="true" Mask="false">{6F2BE26CD70B719D}Missions/BasicSurvival_ChernarusMinus/BasicSurvival_World.ent.conf</Config>
    <Config Name="Max Players" Target="GAME_MAX_PLAYERS" Default="" Mode="" Description="Maximum players" Type="Variable" Display="always" Required="true" Mask="false">6</Config>
    <Config Name="Max FPS" Target="MAX_FPS" Default="" Mode="" Description="Server max FPS" Type="Variable" Display="always" Required="false" Mask="false">120</Config>
    <Config Name="Use Env Vars" Target="USE_ENV_VARS" Default="" Mode="" Description="Patch config using environment variables" Type="Variable" Display="advanced-hide" Required="true" Mask="false">true</Config>
    <Config Name="Extra Game Params" Target="GAME_PARAMS" Default="" Mode="" Description="Leave blank unless needed" Type="Variable" Display="advanced-hide" Required="false" Mask="false"></Config>
    <Config Name="Validate Install" Target="VALIDATE" Default="" Mode="" Description="Set true to validate files" Type="Variable" Display="advanced-hide" Required="false" Mask="false"></Config>
    <Config Name="UID" Target="UID" Default="" Mode="" Description="Container user ID" Type="Variable" Display="advanced-hide" Required="true" Mask="false">99</Config>
    <Config Name="GID" Target="GID" Default="" Mode="" Description="Container group ID" Type="Variable" Display="advanced-hide" Required="true" Mask="false">100</Config>
    <Config Name="UMASK" Target="UMASK" Default="" Mode="" Description="Container umask" Type="Variable" Display="advanced-hide" Required="true" Mask="false">000</Config>

    <Config Name="Game Port Variable" Target="GAME_PORT" Default="" Mode="" Description="Internal game port" Type="Variable" Display="always" Required="true" Mask="false">2001</Config>
    <Config Name="RCON Port Variable" Target="RCON_PORT" Default="" Mode="" Description="Internal RCON port" Type="Variable" Display="always" Required="true" Mask="false">19999</Config>
    <Config Name="A2S Port Variable" Target="A2S_PORT" Default="" Mode="" Description="Internal A2S port" Type="Variable" Display="always" Required="true" Mask="false">17777</Config>

    <Config Name="Game Port" Target="2001" Default="" Mode="udp" Description="UDP game port" Type="Port" Display="always" Required="true" Mask="false">2001</Config>
    <Config Name="RCON Port" Target="19999" Default="" Mode="udp" Description="UDP RCON port" Type="Port" Display="always" Required="true" Mask="false">19999</Config>
    <Config Name="A2S Port" Target="17777" Default="" Mode="udp" Description="UDP A2S port" Type="Port" Display="always" Required="true" Mask="false">17777</Config>
</Container>
